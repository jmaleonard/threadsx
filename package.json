{
  "name": "threads",
  "version": "1.7.0",
  "description": "Web workers & worker threads as simple as a function call",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist-esm/index.js",
  "scripts": {
    "clean": "rimraf dist/ dist-esm/",
    "dev": "npm run clean && tsc -p tsconfig.json --watch",
    "build": "npm run clean && npm run build:cjs && npm run build:es",
    "build:cjs": "tsc -p tsconfig.json",
    "build:es": "tsc -p tsconfig-esm.json",
    "postbuild": "npm run bundle",
    "bundle": "rollup -c -f umd --file=bundle/worker.js --name=threads --silent -- dist-esm/worker/bundle-entry.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "npm run lint && npm run test:library && npm run test:tooling && npm run test:browser",
    "test:library": "ava ./test/**/*.test.ts",
    "test:tooling": "ava ./test-tooling/**/*.test.ts",
    "test:browser": "playwright test",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist-esm/index.js",
      "import": "./index.mjs",
      "require": "./dist/index.js"
    },
    "./observable": {
      "types": "./dist/observable.d.ts",
      "module": "./dist-esm/observable.js",
      "import": "./observable.mjs",
      "require": "./dist/observable.js"
    },
    "./register": {
      "module": "./dist-esm/master/register.js",
      "import": "./register.mjs",
      "require": "./dist/master/register.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "module": "./dist-esm/worker/index.js",
      "import": "./worker.mjs",
      "require": "./dist/worker/index.js"
    }
  },
  "sideEffects": [
    "./dist*/master/register.js",
    "./dist*/worker/index.js",
    "./register.mjs",
    "./worker.mjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andywer/threads.js.git"
  },
  "author": "Andy Wermke (https://github.com/andywer)",
  "bugs": {
    "url": "https://github.com/andywer/threads.js/issues"
  },
  "funding": "https://github.com/andywer/threads.js?sponsor=1",
  "homepage": "https://threads.js.org",
  "keywords": [
    "thread",
    "worker",
    "pool",
    "spawn",
    "isomorphic",
    "parallel",
    "observable",
    "worker_threads"
  ],
  "dependencies": {
    "callsites": "^3.1.0",
    "debug": "^4.4.3",
    "observable-fns": "^0.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/debug": "^4.1.12",
    "@types/execa": "^2.0.0",
    "@types/node": "^20.19.0",
    "ava": "^7.0.0",
    "esbuild": "^0.25.12",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^9.1.2",
    "execa": "^4.0.3",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.0.1",
    "rollup": "^4.62.0",
    "ts-loader": "^9.6.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2"
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "nodeArguments": [
      "--import=tsx"
    ],
    "workerThreads": false,
    "files": [
      "./test/**/*.test.ts",
      "./test-tooling/**/*.test.ts"
    ],
    "serial": true
  },
  "browser": {
    "callsites": false,
    "tsx": false,
    "tsx/cjs": false,
    "ts-node": false,
    "ts-node/register": false,
    "worker_threads": false,
    "./dist/master/implementation.js": "./dist/master/implementation.browser.js",
    "./dist/master/implementation.node.js": false,
    "./dist/worker/implementation.js": "./dist/worker/implementation.browser.js",
    "./dist/worker/implementation.worker_threads.js": false,
    "./dist-esm/master/implementation.js": "./dist-esm/master/implementation.browser.js",
    "./dist-esm/master/implementation.node.js": false,
    "./dist-esm/worker/implementation.js": "./dist-esm/worker/implementation.browser.js",
    "./dist-esm/worker/implementation.worker_threads.js": false
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**",
    "dist-esm/**",
    "index.mjs",
    "observable.mjs",
    "register.mjs",
    "worker.mjs"
  ]
}
